{
  "info": {
    "name": "Staff API",
    "_postman_id": "e2f7d164-6c32-4d3c-9c3a-1234567890ab",
    "description": "Postman tests for Mock Staff Search API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('body is {"status":"ok"}', function () {",
              "  pm.expect(pm.response.json()).to.eql({ status: 'ok' });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "List Staff (defaults)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/staff",
          "host": ["{{baseUrl}}"],
          "path": ["staff"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('response has pagination fields', function () {",
              "  pm.expect(body).to.have.property('total');",
              "  pm.expect(body).to.have.property('page');",
              "  pm.expect(body).to.have.property('page_size');",
              "  pm.expect(body).to.have.property('items');",
              "  pm.expect(Array.isArray(body.items)).to.be.true;",
              "});",
              "",
              "pm.test('items shape is valid when present', function () {",
              "  if (body.items.length > 0) {",
              "    const s = body.items[0];",
              "    pm.expect(s).to.have.property('id');",
              "    pm.expect(s).to.have.property('name');",
              "    pm.expect(s).to.have.property('email');",
              "    pm.expect(s).to.have.property('department');",
              "    pm.expect(s).to.have.property('role');",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Search Staff (q=alice)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/staff?q=alice",
          "host": ["{{baseUrl}}"],
          "path": ["staff"],
          "query": [
            {
              "key": "q",
              "value": "alice"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('has items and items match query', function () {",
              "  pm.expect(body.items.length).to.be.greaterThan(0);",
              "  const matches = body.items.every(s =>",
              "    (s.name || '').toLowerCase().includes('alice') ||",
              "    (s.email || '').toLowerCase().includes('alice')",
              "  );",
              "  pm.expect(matches).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Filter by Department (Engineering)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/staff?department=Engineering",
          "host": ["{{baseUrl}}"],
          "path": ["staff"],
          "query": [
            { "key": "department", "value": "Engineering" }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('all items in Engineering', function () {",
              "  const ok = body.items.every(s => (s.department || '').toLowerCase() === 'engineering'.toLowerCase());",
              "  pm.expect(ok).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Staff by ID (1)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/staff/1",
          "host": ["{{baseUrl}}"],
          "path": ["staff", "1"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const s = pm.response.json();",
              "pm.test('shape is valid', function () {",
              "  pm.expect(s).to.have.property('id');",
              "  pm.expect(s).to.have.property('name');",
              "  pm.expect(s).to.have.property('email');",
              "  pm.expect(s).to.have.property('department');",
              "  pm.expect(s).to.have.property('role');",
              "});",
              "pm.test('id equals 1', function () {",
              "  pm.expect(s.id).to.eql(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Staff by ID (not found)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/staff/9999",
          "host": ["{{baseUrl}}"],
          "path": ["staff", "9999"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 404', function () {",
              "  pm.response.to.have.status(404);",
              "});",
              "const body = pm.response.json();",
              "pm.test('has detail message', function () {",
              "  pm.expect(body).to.have.property('detail');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
